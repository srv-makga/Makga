@page "/process-chain"
@inject AgentRegistry Registry
@inject IJSRuntime JSRuntime
@using DeployTool.Common.Packets

<PageTitle>프로세스 체인 실행</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
	<h2>프로세스 체인 실행</h2>
	<div>
		<button class="btn btn-primary btn-sm" @onclick="ExecuteChainAsync" disabled="@(_executing || GetSelectedProcessCount() == 0)">
			@if (_executing)
			{
				<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
				<span>실행 중...</span>
			}
			else
			{
				<span>@GetSelectedProcessCount()개 프로세스 순차 실행</span>
			}
		</button>
		<button class="btn btn-outline-secondary btn-sm" @onclick="ClearSelectionAsync" disabled="@(GetSelectedProcessCount() == 0)">
			선택 해제
		</button>
	</div>
</div>

@if (_executing || _executionLog.Count > 0)
{
	<div class="card mb-3 bg-dark border-secondary">
		<div class="card-header">
			<h5 class="mb-0">실행 로그</h5>
		</div>
		<div class="card-body" style="max-height: 300px; overflow-y: auto;">
			@foreach (var log in _executionLog)
			{
				<div class="mb-2">
					<small class="@(log.IsSuccess ? "text-success" : "text-warning")">
						[@log.Timestamp.ToString("HH:mm:ss")]
						@if (log.IsSuccess)
						{
							<i class="bi bi-check-circle"></i>
						}
						else
						{
							<i class="bi bi-exclamation-circle"></i>
						}
						@log.Message
					</small>
				</div>
			}
		</div>
	</div>
}

<!-- Agent 및 프로세스 목록 -->
<div class="card">
	<div class="card-body">
		@if (_agents == null || _agents.Count == 0)
		{
			<div class="alert alert-info">Agent를 불러오는 중...</div>
		}
		else
		{
			<div class="list-group list-group-flush">
				@foreach (var agent in _agents)
				{
					var agentKey = agent.Info.Name;
					var isExpanded = _expandedAgents.Contains(agentKey);
					var processCount = _agentProcesses.ContainsKey(agentKey) ? _agentProcesses[agentKey].Count : 0;

					<div class="list-group-item bg-dark border-secondary">
						<!-- Agent 헤더 (체크박스 없음, 폴딩 가능) -->
						<div class="d-flex align-items-center justify-content-between" @onclick="() => ToggleAgentExpand(agentKey)" style="cursor: pointer;">
							<div class="d-flex align-items-center flex-grow-1">
								<i class="bi @(isExpanded ? "bi-chevron-down" : "bi-chevron-right") me-2"></i>
								<div>
									<h6 class="mb-1">
										@agent.Info.Name
										@if (agent.IsConnected)
										{
											<span class="badge bg-success ms-2">Online</span>
										}
										else
										{
											<span class="badge bg-danger ms-2">Offline</span>
										}
									</h6>
									<small class="text-muted">@agent.Info.Host:@agent.Info.Port</small>
								</div>
							</div>
							<span class="badge bg-secondary">@processCount 프로세스</span>
						</div>

						<!-- 프로세스 목록 (폴드) -->
						@if (isExpanded && _agentProcesses.ContainsKey(agentKey))
						{
							<div class="mt-3 ps-4 border-start border-secondary">
								@if (_agentProcesses[agentKey].Count == 0)
								{
									<div class="alert alert-sm alert-secondary mb-0">프로세스 없음</div>
								}
								else
								{
									@foreach (var proc in _agentProcesses[agentKey])
									{
										var processId = $"{agentKey}#{proc.Uid}";
										var isSelected = _selectedProcesses.ContainsKey(processId);

										<div class="form-check mb-2">
											<input class="form-check-input" type="checkbox" id="@processId" 
												   @onchange="@((ChangeEventArgs e) => ToggleProcessSelection(processId, agentKey, proc, (bool)e.Value!))" 
												   checked="@isSelected" />
											<label class="form-check-label" for="@processId">
												<strong>@proc.DisplayName</strong>
												@if (proc.Status == "Running")
												{
													<span class="badge bg-success">Running</span>
												}
												else
												{
													<span class="badge bg-danger">Stopped</span>
												}
												<br />
												<small class="text-muted">@proc.Name (@proc.Priority)</small>
											</label>
										</div>
									}
								}
							</div>
						}
					</div>
				}
			</div>
		}
	</div>
</div>

<!-- 선택된 프로세스 순서 -->
@if (_selectedProcesses.Count > 0)
{
	<div class="card mt-3">
		<div class="card-header">
			<h5 class="mb-0">실행 순서 (총 @GetSelectedProcessCount()개)</h5>
		</div>
		<div class="card-body">
			<ol class="mb-0">
				@{
					int order = 1;
					foreach (var (processId, info) in _selectedProcesses.OrderedItems)
					{
						<li class="mb-2">
							<strong>@info.AgentName</strong> > <strong>@info.ProcessDisplayName</strong>
							<button class="btn btn-sm btn-outline-danger ms-2" @onclick="() => RemoveFromSelection(processId)">
								<i class="bi bi-x"></i>
							</button>
						</li>
						order++;
					}
				}
			</ol>
		</div>
	</div>
}
