@page "/settings"
@inject ManagerSettingsService SettingsSvc

<PageTitle>@L["PageTitle_Settings"]</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@L["Nav_Settings"]</h2>
</div>

<div class="card p-4" style="max-width:480px">
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success") mb-3">@_message</div>
    }

    <div class="mb-3">
        <label class="form-label">@L["Settings_RetryInterval"] (초)</label>
        <input type="number" class="form-control bg-dark text-white" min="1" max="300"
               @bind="_retryIntervalSec" />
        <div class="form-text text-muted">@L["Settings_RetryIntervalDesc"]</div>
    </div>

    <div class="mb-4">
        <label class="form-label">@L["Settings_HeartbeatInterval"] (초)</label>
        <input type="number" class="form-control bg-dark text-white" min="1" max="60"
               @bind="_heartbeatIntervalSec" />
        <div class="form-text text-muted">@L["Settings_HeartbeatIntervalDesc"]</div>
    </div>

    <button class="btn btn-warning" @onclick="SaveAsync" disabled="@_saving">
        @(_saving ? L["Btn_Saving"].Value : L["Btn_Save"].Value)
    </button>
</div>


