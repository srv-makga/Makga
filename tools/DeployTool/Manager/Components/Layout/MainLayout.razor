@inherits LayoutComponentBase
@inject NavigationManager Nav

<style>
	:root {
		color-scheme: dark;
	}
	body {
		color: white;
		background-color: #1a1a1a;
	}
	.text-white { color: white !important; }
	.text-muted { color: #999 !important; }
</style>

<nav class="navbar navbar-expand-lg navbar-dark mb-4">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">🚀 DeployTool</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Dashboard</NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/agents">Agents</NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/process-chain">프로세스 체인</NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/settings">@L["Nav_Settings"]</NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/patch">@L["Nav_Patch"]</NavLink></li>
            </ul>
            <div class="d-flex gap-2">
                <a class="btn btn-sm btn-outline-light" href="@GetCultureUrl("ko")">한국어</a>
                <a class="btn btn-sm btn-outline-light" href="@GetCultureUrl("en")">English</a>
            </div>
        </div>
    </div>
</nav>

<div class="container">
    @Body
</div>

@code {
    private string GetCultureUrl(string culture)
    {
        var returnUrl = Uri.EscapeDataString(new Uri(Nav.Uri).PathAndQuery);
        return $"/culture/set?culture={culture}&returnUrl={returnUrl}";
    }
}
